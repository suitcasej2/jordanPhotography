generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Catalog {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  clientName   String?
  passwordHash String
  expiresAt    DateTime
  coverPhotoId String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  coverPhoto   Photo?   @relation("CatalogCoverPhoto", fields: [coverPhotoId], references: [id], onDelete: SetNull)
  photos       Photo[]  @relation("CatalogPhotos")
}

model Photo {
  id           String   @id @default(cuid())
  catalogId    String
  catalog      Catalog  @relation("CatalogPhotos", fields: [catalogId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  width        Int?
  height       Int?
  sizeBytes    Int
  sortOrder    Int      @default(0)
  storageUrl   String?
  createdAt    DateTime @default(now())
  coverFor     Catalog? @relation("CatalogCoverPhoto")

  @@index([catalogId])
}
